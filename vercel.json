{
  "version": 2,
  "rewrites": [
    { "source": "/game/(.*)", "destination": "/public/game/$1" },
    { "source": "/", "destination": "/public/game/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" }
      ]
    }
  ]
}
