{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/game/(.*)",
      "destination": "/public/game/$1"
    },
    {
      "source": "/",
      "destination": "/public/game/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/public/game/$1"
    }
  ]
}
